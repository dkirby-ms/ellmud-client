/* ===== Global Reset & Root ===== */
.root-container {
    flex-grow: 1;
    background-color: rgb(18, 18, 24);
    flex-direction: column;
}

/* ===== Room Header ===== */
.room-header {
    flex-direction: row;
    padding: 8px 12px;
    background-color: rgb(30, 30, 42);
    border-bottom-width: 1px;
    border-bottom-color: rgb(60, 60, 80);
    align-items: center;
}
.room-name {
    font-size: 16px;
    color: rgb(200, 180, 140);
    -unity-font-style: bold;
    margin-right: 12px;
}
.zone-name {
    font-size: 12px;
    color: rgb(120, 120, 140);
}
.exits-container {
    flex-direction: row;
    margin-left: auto;
}
.exit-button {
    font-size: 11px;
    color: rgb(100, 180, 255);
    background-color: rgba(0, 0, 0, 0);
    border-width: 1px;
    border-color: rgb(60, 60, 80);
    border-radius: 3px;
    padding: 2px 8px;
    margin-left: 4px;
}
.exit-button:hover {
    background-color: rgb(40, 40, 60);
}

/* ===== Main Layout ===== */
.main-area {
    flex-grow: 1;
    flex-direction: row;
}

/* ===== Terminal ===== */
.terminal-scroll {
    flex-grow: 1;
    padding: 8px 12px;
}
.terminal-content {
    flex-direction: column;
}
.narration-line {
    font-size: 14px;
    color: rgb(200, 200, 210);
    margin-bottom: 2px;
    white-space: normal;
}
/* Narration type color classes */
.narration-combat    { color: rgb(255, 100, 100); }
.narration-system    { color: rgb(255, 220, 100); }
.narration-speech    { color: rgb(100, 220, 255); }
.narration-sound     { color: rgb(180, 140, 255); }
.narration-trace     { color: rgb(120, 120, 130); }
.narration-ambient   { color: rgb(100, 140, 100); }
.narration-awareness { color: rgb(200, 160, 100); }

/* ===== Sidebar ===== */
.sidebar {
    width: 260px;
    min-width: 200px;
    padding: 8px;
    background-color: rgb(24, 24, 34);
    border-left-width: 1px;
    border-left-color: rgb(60, 60, 80);
    flex-direction: column;
}

/* ===== Player HUD ===== */
.player-hud { margin-bottom: 12px; }
.hud-title {
    font-size: 13px;
    color: rgb(160, 160, 180);
    -unity-font-style: bold;
    margin-bottom: 6px;
}
.hp-bar .unity-progress-bar__background {
    background-color: rgb(60, 20, 20);
}
.hp-bar .unity-progress-bar__progress {
    background-color: rgb(200, 60, 60);
}
.stamina-bar .unity-progress-bar__background {
    background-color: rgb(20, 40, 60);
}
.stamina-bar .unity-progress-bar__progress {
    background-color: rgb(60, 140, 200);
}
.posture-label {
    font-size: 12px;
    color: rgb(140, 140, 160);
    margin-top: 4px;
}
.status-effects { flex-direction: row; flex-wrap: wrap; margin-top: 4px; }
.status-effect-tag {
    font-size: 10px;
    color: rgb(255, 200, 100);
    background-color: rgb(60, 50, 30);
    border-radius: 3px;
    padding: 2px 6px;
    margin: 2px;
}

/* ===== Combat HUD ===== */
.combat-hud { flex-grow: 1; }
.combat-title { color: rgb(255, 100, 100); }
.combat-tick {
    font-size: 11px;
    color: rgb(140, 140, 160);
    margin-bottom: 6px;
}
.combatant-row {
    flex-direction: row;
    align-items: center;
    padding: 4px;
    margin-bottom: 2px;
    border-radius: 3px;
}
.combatant-hostile { background-color: rgba(255, 60, 60, 0.1); }
.combatant-friendly { background-color: rgba(60, 200, 60, 0.1); }
.combatant-name {
    font-size: 12px;
    color: rgb(200, 200, 210);
    width: 100px;
}
.combatant-hp-bar { flex-grow: 1; height: 8px; }

/* ===== Command Input ===== */
.input-area {
    flex-direction: row;
    padding: 6px 12px;
    background-color: rgb(24, 24, 34);
    border-top-width: 1px;
    border-top-color: rgb(60, 60, 80);
    align-items: center;
}
.prompt-char {
    font-size: 16px;
    color: rgb(100, 255, 100);
    margin-right: 8px;
    -unity-font-style: bold;
}
.command-input { flex-grow: 1; }
.command-input .unity-base-text-field__input {
    background-color: rgb(18, 18, 24);
    border-width: 0;
    color: rgb(200, 200, 210);
    font-size: 14px;
    padding: 4px 8px;
}
.command-input .unity-base-text-field__input:focus {
    border-width: 0;
}

/* ===== Overlays ===== */
.overlay-container {
    position: absolute;
    left: 0; top: 0; right: 0; bottom: 0;
    background-color: rgba(0, 0, 0, 0.85);
    align-items: center;
    justify-content: center;
}
.overlay-content {
    background-color: rgb(30, 30, 42);
    border-radius: 8px;
    padding: 24px;
    max-width: 500px;
    border-width: 1px;
    border-color: rgb(80, 60, 60);
}
.overlay-title {
    font-size: 20px;
    color: rgb(255, 100, 100);
    -unity-font-style: bold;
    -unity-text-align: middle-center;
    margin-bottom: 12px;
}
.overlay-text {
    font-size: 14px;
    color: rgb(200, 200, 210);
    white-space: normal;
    margin-bottom: 16px;
}
.overlay-button {
    padding: 8px 24px;
    font-size: 14px;
    background-color: rgb(60, 60, 80);
    color: rgb(200, 200, 210);
    border-radius: 4px;
    border-width: 0;
    align-self: center;
}

/* ===== Utility ===== */
.hidden { display: none; }