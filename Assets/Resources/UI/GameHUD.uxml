<ui:UXML xmlns:ui="UnityEngine.UIElements">
    <ui:Style src="EllmudTheme.uss" />

    <!-- Root container fills the screen -->
    <ui:VisualElement name="root" class="root-container">

        <!-- Room Header Bar -->
        <ui:VisualElement name="room-header" class="room-header">
            <ui:Label name="room-name" text="Unknown Room" class="room-name" />
            <ui:Label name="zone-name" text="" class="zone-name" />
            <ui:VisualElement name="exits-container" class="exits-container" />
        </ui:VisualElement>

        <!-- Main content area: terminal + sidebar -->
        <ui:VisualElement name="main-area" class="main-area">

            <!-- Narration Terminal -->
            <ui:ScrollView name="terminal-scroll" mode="Vertical"
                           vertical-scroller-visibility="Auto"
                           class="terminal-scroll">
                <ui:VisualElement name="terminal-content"
                                  class="terminal-content" />
            </ui:ScrollView>

            <!-- Right sidebar: player status + combat -->
            <ui:VisualElement name="sidebar" class="sidebar">
                <!-- Player Status HUD -->
                <ui:VisualElement name="player-hud" class="player-hud">
                    <ui:Label name="player-name" text="Player"
                              class="hud-title" />
                    <ui:ProgressBar name="hp-bar" title="HP"
                                    high-value="100" class="hp-bar" />
                    <ui:ProgressBar name="stamina-bar" title="Stamina"
                                    high-value="100" class="stamina-bar" />
                    <ui:Label name="posture-label" text="Posture: Balanced"
                              class="posture-label" />
                    <ui:VisualElement name="status-effects"
                                      class="status-effects" />
                </ui:VisualElement>

                <!-- Combat HUD (hidden by default) -->
                <ui:VisualElement name="combat-hud" class="combat-hud hidden">
                    <ui:Label text="⚔ COMBAT"
                              class="hud-title combat-title" />
                    <ui:Label name="combat-tick" text=""
                              class="combat-tick" />
                    <ui:ScrollView name="combatants-list"
                                   class="combatants-list" />
                </ui:VisualElement>
            </ui:VisualElement>

        </ui:VisualElement>

        <!-- Command Input -->
        <ui:VisualElement name="input-area" class="input-area">
            <ui:Label text=">" class="prompt-char" />
            <ui:TextField name="command-input" class="command-input" />
        </ui:VisualElement>

        <!-- Overlay container (death, permadeath, character select) -->
        <ui:VisualElement name="overlay-container"
                          class="overlay-container hidden" />

    </ui:VisualElement>
</ui:UXML>